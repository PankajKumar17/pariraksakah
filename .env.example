# === CyberShield-X Environment Variables ===

# PostgreSQL / TimescaleDB
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=cybershield
POSTGRES_USER=cybershield
POSTGRES_PASSWORD=changeme_postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j

# API Gateway
API_GATEWAY_PORT=8080
JWT_SECRET=changeme_jwt_secret
JWT_ISSUER=cybershield-x

# Threat Detection
ATDE_MODEL_PATH=/app/ml-models/saved/
ATDE_INFERENCE_PORT=8001
TRITON_SERVER_URL=triton:8000

# Access Control
ACCESS_CONTROL_PORT=8002
SOFTHSM2_CONF=/etc/softhsm2.conf
PQC_KEY_STORE=/app/keys/

# Anti-Phishing
ANTI_PHISHING_PORT=8003
VIRUSTOTAL_API_KEY=changeme_virustotal
URLHAUS_API_URL=https://urlhaus-api.abuse.ch/v1/

# Incident Response
INCIDENT_RESPONSE_PORT=8004
CLAUDE_API_KEY=changeme_claude_api_key

# Bio-Auth
BIO_AUTH_PORT=8005

# Swarm Agent
SWARM_AGENT_PORT=8006

# Cognitive Firewall
COGNITIVE_FIREWALL_PORT=8007

# Self-Healing
SELF_HEALING_PORT=8008

# Prometheus / Grafana
GRAFANA_ADMIN_PASSWORD=changeme_grafana

# S3 / Object Storage
S3_BUCKET=cybershield-evidence
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=changeme
AWS_SECRET_ACCESS_KEY=changeme

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
